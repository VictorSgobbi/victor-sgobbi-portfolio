rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidAnalyticsEvent() {
      let data = request.resource.data;
      let validTypes = ["session", "click", "duration", "login_attempt"];

      // Deve ter type e timestamp
      return data.keys().hasAll(["type", "timestamp"])
        // type deve ser um dos valores válidos
        && data.type in validTypes
        // Não pode ter campos extras além dos permitidos
        && data.keys().hasOnly(["type", "timestamp", "sessionId", "elementId", "projectId", "duration", "success", "userAgent"])
        // sessionId deve ser string
        && (!"sessionId" in data.keys() || data.sessionId is string)
        // duration deve ser número positivo se presente
        && (!("duration" in data.keys()) || (data.duration is number && data.duration > 0 && data.duration < 86400));
    }

    match /analytics/{id} {
      allow create: if isValidAnalyticsEvent();
      allow read:   if isAuthenticated();
      allow update, delete: if false;
    }

    match /feedbacks/{id} {
      allow create: if true;
      allow read:   if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
